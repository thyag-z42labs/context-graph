# Root environment example for create-context-graph development.
# Copy to .env and fill in only the keys you need:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# Agent answering model routing
# ---------------------------------------------------------------------------
# auto = use OpenRouter when OPENROUTER_API_KEY is set, otherwise use the
# selected framework's legacy provider.
AGENT_PROVIDER=auto
AGENT_MODEL=
AGENT_FALLBACK_PROVIDER=legacy

OPENROUTER_API_KEY=
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_APP_URL=
OPENROUTER_APP_TITLE=context-graph

# Legacy / fallback agent providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ---------------------------------------------------------------------------
# Graph/context generation model routing
# ---------------------------------------------------------------------------
# Answering LLM: AGENT_PROVIDER / AGENT_MODEL.
# Memory/context extraction: MEMORY_LLM / MEMORY_EMBEDDING.
# Synthetic graph fixtures: FIXTURE_GENERATION_PROVIDER / FIXTURE_GENERATION_MODEL.
# Custom ontology generation: ONTOLOGY_GENERATION_MODEL.
GENERATION_PROVIDER=auto
GENERATION_MODEL=
FIXTURE_GENERATION_PROVIDER=auto
FIXTURE_GENERATION_MODEL=
ONTOLOGY_GENERATION_MODEL=

# ---------------------------------------------------------------------------
# Memory backend and memory-layer providers
# ---------------------------------------------------------------------------
# nams = hosted Neo4j Agent Memory Service; bolt = self-hosted Neo4j.
MEMORY_BACKEND=nams
MEMORY_API_KEY=
MEMORY_NAMS_ENDPOINT=https://memory.neo4jlabs.com/v1

# Optional memory-layer LiteLLM-style providers. Separate from AGENT_PROVIDER.
MEMORY_LLM=
MEMORY_EMBEDDING=

# Self-hosted Neo4j / Aura / local bolt path
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# ---------------------------------------------------------------------------
# SaaS connectors
# ---------------------------------------------------------------------------
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_LIMIT=20
GITHUB_ISSUES_LIMIT=0
GITHUB_PRS_LIMIT=0
GITHUB_COMMITS_LIMIT=0
GITHUB_IMPORT_BODY=true
GITHUB_LINK_ISSUES_PRS=true
GITHUB_LINK_SOURCE=both

NOTION_TOKEN=

JIRA_URL=
JIRA_EMAIL=
JIRA_TOKEN=
JIRA_PROJECT=

SLACK_TOKEN=
SLACK_CHANNELS=

SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
SALESFORCE_DOMAIN=login

LINEAR_API_KEY=
LINEAR_TEAM=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GWS_FOLDER_ID=

# Claude Code import settings
CLAUDE_CODE_SCOPE=current
CLAUDE_CODE_SINCE=
CLAUDE_CODE_MAX_SESSIONS=0
CLAUDE_CODE_CONTENT_MODE=truncated
CLAUDE_CODE_BASE_PATH=

# ---------------------------------------------------------------------------
# Generated app defaults
# ---------------------------------------------------------------------------
DOMAIN_ID=
SESSION_STRATEGY=per_conversation
BACKEND_PORT=8000
FRONTEND_PORT=3000
CORS_ORIGINS=http://localhost:3000

# HuggingFace / local embedding downloads
HF_HUB_DISABLE_TELEMETRY=1
HF_TOKEN=
